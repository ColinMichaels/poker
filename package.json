{
  "private": true,
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "npm run dev:client --prefix modern",
    "dev:client": "npm run dev:client --prefix modern",
    "dev:server": "npm run dev:server --prefix modern",
    "ci": "npm run doctor && npm run ci --prefix modern",
    "doctor": "node ./scripts/doctor-modern-env.mjs",
    "typecheck": "npm run typecheck --prefix modern",
    "build": "npm run build --prefix modern",
    "test": "npm run test:engine --prefix modern && npm run test:server --prefix modern",
    "legacy:dev": "node ./scripts/run-legacy-archive-command.mjs dev",
    "legacy:build": "node ./scripts/run-legacy-archive-command.mjs prod"
  }
}
