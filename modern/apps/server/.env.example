# Modern server environment example
# Copy to your deployment env management system and adjust per environment.

# Environment mode (affects default compatibility toggles)
NODE_ENV=development

# Runtime networking
HOST=127.0.0.1
PORT=8787
TABLE_ID=table-1

# Runtime persistence
POKER_STATE_PERSIST=1
POKER_STATE_FILE=apps/server/.data/runtime-state.json

# Auth/session hardening
POKER_AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
POKER_SESSION_TTL_MS=28800000

# External identity integration (signed assertion exchange)
POKER_EXTERNAL_AUTH_ENABLED=0
POKER_EXTERNAL_AUTH_ISSUER=external-idp
POKER_EXTERNAL_AUTH_SHARED_SECRET=replace-with-a-separate-long-random-secret
POKER_EXTERNAL_AUTH_SHARED_SECRET_PREVIOUS=

# Auth bootstrap controls
# In production, demo users default to disabled unless explicitly enabled.
POKER_AUTH_ALLOW_DEMO_USERS=0
POKER_AUTH_BOOTSTRAP_USERS_FILE=apps/server/bootstrap-users.example.json

# Legacy compatibility controls
# In production, legacy wallet routes default to disabled unless explicitly enabled.
POKER_ENABLE_LEGACY_WALLET_ROUTES=0
