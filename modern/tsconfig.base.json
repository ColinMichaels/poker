{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@poker/poker-engine": ["packages/poker-engine/src/index.ts"],
      "@poker/game-contracts": ["packages/game-contracts/src/index.ts"],
      "@poker/asset-manifest": ["packages/asset-manifest/src/index.ts"]
    }
  }
}
